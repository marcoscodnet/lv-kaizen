# =========================
# DEPENDENCIAS
# =========================
/node_modules/
/vendor/

# =========================
# COMPILADOS FRONTEND
# =========================
/public/build/
/public/dist/
/public/mix-manifest.json

# Si usás assets compilados por gulp/vite
/public/assets/css/*.map
/public/assets/js/*.map

# =========================
# ARCHIVOS GENERADOS / CACHE
# =========================
/storage/*.key
/storage/logs/
/storage/framework/cache/
/storage/framework/sessions/
/storage/framework/views/

# =========================
# ARCHIVOS DE ENTORNO
# =========================
.env
.env.backup
.env.production
.env.local

# =========================
# LOGS Y TEMPORALES
# =========================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# =========================
# SISTEMA OPERATIVO / IDE
# =========================
.DS_Store
Thumbs.db

.vscode/
.idea/

# =========================
# BACKUPS Y COSAS LOCALES
# =========================
vendor_old/
composer_old.lock

# =========================
# ARCHIVOS DE BUILD MANUAL
# =========================
/build/
/public/files/
/public/images/piezas/
